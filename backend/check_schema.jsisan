const { Pool } = require('pg');
const pool = new Pool({ host: 'localhost', port: 5432, user: 'postgres', password: '1234', database: 'chamasmart' });
async function run() {
  try {
    const res = await pool.query("SELECT column_name, data_type FROM information_schema.columns WHERE table_name = 'notifications';");
    console.log(JSON.stringify(res.rows, null, 2));
  } catch(e) { console.error(e.message); } finally { await pool.end(); }
}
run();
